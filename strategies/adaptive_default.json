{
  "name": "adaptive_default",
  "description": "自适应权重策略：基于滚动6个月信号准确率动态调整权重，其余参数同 default",

  "rating_weights": {
    "screener": 0.25,
    "valuation": 0.30,
    "buffett": 0.20,
    "munger": 0.15,
    "chan": 0.10
  },
  "rating_thresholds": {
    "A+": 85, "A": 70, "B": 55, "C": 40
  },

  "buy_ratings": ["A+", "A"],
  "position_sizes": { "A+": 0.20, "A": 0.15 },
  "resonance_boost": 1.5,
  "high_score_boost": 1.2,
  "high_score_threshold": 80,
  "max_single_position": 0.25,
  "max_holdings": 10,

  "stop_loss_pct": -0.10,
  "take_profit_pct": null,
  "sell_on_downgrade_to": ["C", "D"],

  "checkpoint_frequency": "monthly",
  "initial_capital": 100000,
  "min_rebalance_diff": 1000,
  "lot_size": 100,

  "adaptive_weights": true,
  "adaptive_window_months": 6,
  "adaptive_forward_days": 20,
  "adaptive_exponent": 2.0,
  "adaptive_min_weight": 0.05,
  "adaptive_smoothing": 0.3
}
