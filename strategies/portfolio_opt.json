{
  "name": "portfolio_opt",
  "description": "组合优化策略：concentrated_v2 + 相关性约束 + 行业集中度上限",

  "rating_weights": {
    "screener": 0.25,
    "valuation": 0.30,
    "buffett": 0.20,
    "munger": 0.15,
    "chan": 0.10
  },
  "rating_thresholds": {
    "A+": 85, "A": 70, "B": 55, "C": 40
  },

  "buy_ratings": ["A+", "A"],
  "position_sizes": { "A+": 0.20, "A": 0.15 },
  "resonance_boost": 1.5,
  "high_score_boost": 1.2,
  "high_score_threshold": 80,
  "max_single_position": 0.25,
  "max_holdings": 10,

  "stop_loss_pct": null,
  "take_profit_pct": null,
  "sell_on_downgrade_to": ["C", "D"],

  "checkpoint_frequency": "monthly",
  "initial_capital": 100000,
  "min_rebalance_diff": 1000,
  "lot_size": 100,

  "adaptive_weights": false,

  "atr_stop_enabled": true,
  "atr_stop_multiplier": 2.0,
  "atr_period": 20,
  "trailing_stop_enabled": true,
  "trailing_stop_pct": 0.15,
  "time_stop_months": 6,

  "market_regime_enabled": true,
  "regime_risk_on_mult": 1.2,
  "regime_neutral_mult": 1.0,
  "regime_risk_off_mult": 0.5,

  "sector_rotation_enabled": false,

  "position_concentration_enabled": true,
  "consensus_5_mult": 1.2,
  "consensus_4_mult": 1.1,
  "consensus_3_mult": 1.0,
  "consensus_2_mult": 0.9,
  "accuracy_high_threshold": 0.70,
  "accuracy_high_mult": 1.0,
  "accuracy_mid_threshold": 0.60,
  "accuracy_mid_mult": 1.0,
  "liquidity_high_threshold": 100000000,
  "liquidity_mid_threshold": 50000000,
  "liquidity_low_threshold": 10000000,
  "liquidity_mid_mult": 0.9,
  "liquidity_low_mult": 0.8,

  "scaling_enabled": false,
  "weekly_risk_check": false,

  "portfolio_opt_enabled": true,
  "max_correlation": 0.7,
  "correlation_window_days": 60,
  "max_industry_pct": 0.30
}
